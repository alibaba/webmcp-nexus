{
  "name": "vite-plugin-webmcp-nexus",
  "version": "0.1.11",
  "description": "Vite plugin for WebMCP Nexus - auto-generates JSON Schema from TypeScript tool definitions at build time",
  "license": "MIT",
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "vite",
    "vite-plugin",
    "ai-tools",
    "typescript",
    "build-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alibaba/webmcp-nexus.git",
    "directory": "packages/vite-plugin-webmcp"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "webmcp-nexus-core": "workspace:*",
    "webmcp-nexus-sdk": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsup": "^8.5.0",
    "vite": "^8.0.9"
  }
}
