{
  "name": "webmcp-nexus-sdk",
  "version": "0.1.10",
  "description": "SDK for WebMCP Nexus - register and expose browser-side tools for AI agents via Model Context Protocol",
  "license": "MIT",
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "ai-tools",
    "sdk",
    "react",
    "browser",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alibaba/webmcp-nexus.git",
    "directory": "packages/webmcp-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-b/webmcp-polyfill": "^2.3.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "tsup": "^8.5.0",
    "vitest": "^4.1.5"
  }
}
