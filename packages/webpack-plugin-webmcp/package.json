{
  "name": "webpack-plugin-webmcp-nexus",
  "version": "0.1.11",
  "description": "Webpack plugin for WebMCP Nexus - auto-generates and injects JSON Schema from TypeScript tool definitions at build time",
  "license": "MIT",
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "webpack",
    "webpack-plugin",
    "ai-tools",
    "typescript",
    "build-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alibaba/webmcp-nexus.git",
    "directory": "packages/webpack-plugin-webmcp"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "webmcp-nexus-core": "workspace:*"
  },
  "peerDependencies": {
    "webpack": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsup": "^8.5.0",
    "webpack": "^5.98.0"
  }
}
